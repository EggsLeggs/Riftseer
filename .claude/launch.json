{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["dev:api"],
      "port": 3000
    },
    {
      "name": "Frontend",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["dev:frontend"],
      "port": 5173
    },
    {
      "name": "Docs",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--filter", "docs", "start"],
      "port": 3001
    },
    {
      "name": "Discord Bot",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--filter", "@riftseer/discord-bot", "dev"],
      "port": 8787
    },
    {
      "name": "Ingest Worker",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--filter", "@riftseer/ingest-worker", "dev"],
      "port": 8787
    }
  ]
}
